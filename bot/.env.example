# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Calendar OAuth credentials (path to downloaded JSON from Google Cloud Console)
GOOGLE_OAUTH_CREDENTIALS=/path/to/gcp-oauth.keys.json

# Ollama (for ingest.py — runs locally, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Database
DB_PATH=/app/data/events.db

# Project root (used by bot to locate scripts and CLAUDE.md)
PROJECT_DIR=/app

# GCal notifications — send Telegram notifications when new calendar events appear
# OWNER_CHAT_ID: run /start and check bot logs for your chat ID, then set it here
OWNER_CHAT_ID=
GCAL_POLL_MINUTES=15

# GCal webhook push notifications (recommended — instant alerts, replaces polling)
# Set GCAL_WEBHOOK_URL to enable; leave unset to fall back to polling.
# GCAL_WEBHOOK_TOKEN is a shared secret verified on each incoming notification.
GCAL_WEBHOOK_URL=
GCAL_WEBHOOK_PORT=8080
GCAL_WEBHOOK_TOKEN=
